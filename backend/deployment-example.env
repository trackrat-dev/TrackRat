# TrackCast Production Environment Variables Example
# Copy this file to .env and update with your actual values

# Environment
TRACKCAST_ENV=prod

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/trackcast

# NJ Transit API Credentials
NJT_USERNAME=your_nj_transit_username
NJT_PASSWORD=your_nj_transit_password

# APNS Configuration (Method 1: Auth Key - Recommended)
APNS_TEAM_ID=D5RZZ55J9R
APNS_KEY_ID=XNFHX5SPQL
APNS_AUTH_KEY_PATH=/app/certs/AuthKey_XNFHX5SPQL.p8
APNS_BUNDLE_ID=net.trackrat.TrackRat

# APNS Configuration (Method 2: Certificate - Alternative)
# APNS_CERT_PATH=/app/certs/aps_cert.pem
# APNS_KEY_PATH=/app/certs/aps_key.pem
# APNS_BUNDLE_ID=com.andymartin.TrackRat

# OpenTelemetry (Optional)
OTEL_SAMPLE_RATE=0.1
GOOGLE_CLOUD_PROJECT=your-gcp-project

# Model Configuration
MODEL_PATH=/app/models

# Logging
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Security (if needed)
# SSL_CERT_PATH=/app/certs/server.crt
# SSL_KEY_PATH=/app/certs/server.key