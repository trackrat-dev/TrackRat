# Environment variables for TrackCast inference service
# Copy this file to .env and update with your actual values

# NJ Transit API credentials (required)
NJT_USERNAME=your_nj_transit_username
NJT_PASSWORD=your_nj_transit_password

# Optional: Override default database URL for docker-compose
# DATABASE_URL=postgresql://trackcast:trackcast_dev_password@localhost:5432/trackcast_dev

# Optional: Override model path
# MODEL_PATH=/app/models

# Optional: Set environment
# TRACKCAST_ENV=dev