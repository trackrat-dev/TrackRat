[flake8]
max-line-length = 100
exclude = .git,__pycache__,build,dist,venv
per-file-ignores =
    # Allow imports in __init__.py files
    __init__.py:F401
    # Allow long lines in test files
    tests/*:E501
ignore =
    # Line break before binary operator
    W503
    # Line break after binary operator
    W504
    # Too many leading '#' for block comment
    E266
    # Module level import not at top of file (for path adjustments)
    E402