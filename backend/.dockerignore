# TrackCast Docker ignore file
# Excludes files that should not be included in the Docker build context

# Large data directories (models will be mounted externally)
data/
training_artifacts/

# Additional large files to exclude
arch_docs/
CONTAINERIZATION_SUMMARY.md
DEPLOYMENT.md
DOCKER_README.md
USAGE.md
INDICES.md
docker-compose.yml
check_track_conflicts.py
model.py
init-db.sql
cloudbuild.yaml

