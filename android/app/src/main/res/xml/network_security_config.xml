<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production domain configuration -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">trackrat.net</domain>
        
        <!-- Enforce HTTPS and use system certificate authorities -->
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
        
        <!-- Pin certificates for enhanced security (optional - uncomment and configure if needed)
        <pin-set>
            <pin digest="SHA-256">YOUR_CERTIFICATE_PIN_HERE</pin>
        </pin-set>
        -->
    </domain-config>
    
    <!-- Development/debug configuration for local testing -->
    <debug-overrides>
        <!-- Allow cleartext traffic for local development -->
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>
    
    <!-- Local development domains with cleartext traffic allowed -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain> <!-- Android emulator host -->
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.0.0/8</domain> <!-- Local network range -->
        <domain includeSubdomains="true">192.168.0.0/16</domain> <!-- Local network range -->
    </domain-config>
    
    <!-- Base configuration: HTTPS only by default -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system certificate authorities -->
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>