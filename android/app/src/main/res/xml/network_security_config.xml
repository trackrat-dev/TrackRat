<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production domain configuration -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">trackrat.net</domain>
        <domain includeSubdomains="true">api.trackrat.net</domain>
        <domain includeSubdomains="true">prod.api.trackrat.net</domain>
        
        <!-- Enforce HTTPS and use system certificate authorities -->
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
        
        <!-- Pin certificates for enhanced security (optional - uncomment and configure if needed)
        <pin-set>
            <pin digest="SHA-256">YOUR_CERTIFICATE_PIN_HERE</pin>
        </pin-set>
        -->
    </domain-config>
    
    <!-- Development/debug configuration for local testing -->
    <debug-overrides>
        <!-- Allow cleartext traffic for local development -->
        <domain-config cleartextTrafficPermitted="true">
            <domain>localhost</domain>
            <domain>10.0.2.2</domain> <!-- Android emulator host -->
            <domain>127.0.0.1</domain>
            <domain>10.0.0.0/8</domain> <!-- Local network range -->
            <domain>192.168.0.0/16</domain> <!-- Local network range -->
        </domain-config>
    </debug-overrides>
    
    <!-- Base configuration: HTTPS only by default -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system certificate authorities -->
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>