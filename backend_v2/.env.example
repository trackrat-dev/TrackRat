# TrackRat V2 Backend Configuration
# Copy this file to .env and update with your values

# Environment
TRACKRAT_ENVIRONMENT=development
TRACKRAT_DEBUG=true
TRACKRAT_LOG_LEVEL=INFO

# API Settings
TRACKRAT_API_HOST=0.0.0.0
TRACKRAT_API_PORT=8000

# Database
# SQLite database file path (will be created if it doesn't exist)
TRACKRAT_DATABASE_URL=sqlite:///trackrat_v2.db

# NJ Transit API
TRACKRAT_NJT_API_URL=https://raildata.njtransit.com/api
TRACKRAT_NJT_API_TOKEN=your_token_here

# Collection Settings
TRACKRAT_DISCOVERY_INTERVAL_MINUTES=60
TRACKRAT_JOURNEY_UPDATE_INTERVAL_MINUTES=15
TRACKRAT_DATA_STALENESS_SECONDS=60

# Monitoring
TRACKRAT_ENABLE_METRICS=true

# APNS Configuration (optional - for iOS push notifications)
# See certs/README.md for how to obtain these
# APNS_TEAM_ID=your_team_id
# APNS_KEY_ID=your_key_id
# APNS_AUTH_KEY_PATH=certs/apns_auth_key.p8
# APNS_BUNDLE_ID=net.trackrat.TrackRat
# APNS_ENVIRONMENT=dev
