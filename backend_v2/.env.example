# TrackRat V2 Backend Configuration
# Copy this file to .env and update with your values

# Environment
TRACKRAT_ENVIRONMENT=development
TRACKRAT_DEBUG=true
TRACKRAT_LOG_LEVEL=INFO

# API Settings
TRACKRAT_API_HOST=0.0.0.0
TRACKRAT_API_PORT=8000

# Database (PostgreSQL required)
TRACKRAT_DATABASE_URL=postgresql+asyncpg://trackratuser:password@localhost:5432/trackratdb

# NJ Transit API
TRACKRAT_NJT_API_URL=https://raildata.njtransit.com/api
TRACKRAT_NJT_API_TOKEN=your_njt_api_token_here

# Other Transit APIs (optional - only needed for these systems)
# TRACKRAT_WMATA_API_KEY=your_wmata_developer_api_key
# TRACKRAT_METRA_API_TOKEN=your_metra_api_token
# TRACKRAT_MBTA_API_KEY=your_mbta_api_key

# Feature Flags
# Comma-separated data sources to fully disable (collection + alerts + API serving)
# TRACKRAT_DISABLED_DATA_SOURCES=BART,WMATA,MBTA,METRA

# APNS Settings (optional - for iOS Live Activities)
APNS_TEAM_ID=your_apple_team_id
APNS_KEY_ID=your_apns_key_id
APNS_AUTH_KEY_PATH=certs/apns_auth_key.p8
APNS_BUNDLE_ID=net.trackrat.TrackRat
APNS_ENVIRONMENT=dev

# Collection Settings
TRACKRAT_DISCOVERY_INTERVAL_MINUTES=30
TRACKRAT_JOURNEY_UPDATE_INTERVAL_MINUTES=15
TRACKRAT_DATA_STALENESS_SECONDS=60

# Monitoring
TRACKRAT_ENABLE_METRICS=true

# Backup Settings (optional)
# TRACKRAT_GCS_BACKUP_BUCKET=your-backup-bucket
