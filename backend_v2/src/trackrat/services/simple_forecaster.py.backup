"""
Simple arrival time forecaster using recent trains.

This service predicts arrival times by looking at how long recent trains
took to travel each segment of the journey.
"""

import statistics
from datetime import timedelta
from typing import Any

from sqlalchemy import and_, select
from sqlalchemy.ext.asyncio import AsyncSession
from structlog import get_logger

from trackrat.models.database import SegmentTransitTime, TrainJourney
from trackrat.utils.time import ensure_timezone_aware, now_et

logger = get_logger(__name__)


def _get_station_code(stop: Any) -> str:
    """Get station code from either JourneyStop or StopDetails object."""
    if hasattr(stop, "station_code"):
        return str(stop.station_code)
    elif hasattr(stop, "station") and hasattr(stop.station, "code"):
        return str(stop.station.code)
    else:
        raise AttributeError(f"Cannot get station code from {type(stop)} object")


class SimpleArrivalForecaster:
    """
    Ultra-simple arrival forecaster using recent trains on the same segments.

    Uses only trains from the last hour to capture current conditions.
    """

    LOOKBACK_HOURS = 1  # How far back to look for recent trains
    MIN_SAMPLES = 3  # Minimum trains needed for a prediction
    MAX_SEGMENT_MINUTES = 60  # Maximum believable time for a single segment

    async def add_predictions_to_stops(
        self,
        db: AsyncSession,
        journey: TrainJourney,
        stops: list[Any],
        user_origin: str | None = None,
    ) -> None:
        """
        Add predicted_arrival times to stop objects in-place.

        Args:
            db: Database session
            journey: The train journey
            stops: List of stop objects (modified in-place)
            user_origin: User's boarding station code (if provided, uses scheduled times before this station)
        """
        logger.info(
            "🔮 Starting arrival prediction",
            train_id=journey.train_id,
            journey_date=journey.journey_date,
            num_stops=len(stops),
            user_origin=user_origin,
        )

        if not stops:
            logger.info("🔮 No stops provided, skipping predictions")
            return

        # Sort stops by sequence to ensure correct order
        stops.sort(key=lambda s: s.stop_sequence)

        # Find user's origin station index if provided
        user_origin_index = None
        if user_origin:
            for i, stop in enumerate(stops):
                if _get_station_code(stop) == user_origin:
                    user_origin_index = i
                    logger.info(
                        "👤 Found user's origin station",
                        station=user_origin,
                        index=user_origin_index,
                        has_departed=stop.has_departed_station,
                    )
                    break

        # Find the best reference point for dynamic predictions
        reference_stop, reference_time = self._find_reference_point(stops)
        
        # Determine prediction strategy based on user context and train progress
        if user_origin_index is not None:
            # User has specified origin - always use this as the starting point
            user_origin_stop = stops[user_origin_index]
            
            # Calculate any delay to apply from train's actual progress
            base_delay = timedelta(0)
            if reference_stop is not None:
                base_delay = self._calculate_base_delay(reference_stop, reference_time)
                logger.info(
                    "⚖️ Applying delay from train progress",
                    reference_station=_get_station_code(reference_stop),
                    base_delay_minutes=base_delay.total_seconds() / 60.0,
                    departure_source=getattr(reference_stop, "departure_source", "unknown")
                )
            
            # Use user's origin scheduled departure or current time as baseline
            if (
                hasattr(user_origin_stop, "scheduled_departure")
                and user_origin_stop.scheduled_departure
            ):
                predicted_time = ensure_timezone_aware(user_origin_stop.scheduled_departure) + base_delay
                start_index = user_origin_index
                
                logger.info(
                    "👤 User origin-based prediction mode",
                    user_origin=user_origin,
                    scheduled_departure=(user_origin_stop.scheduled_departure).isoformat() if user_origin_stop.scheduled_departure else None,
                    base_delay_minutes=base_delay.total_seconds() / 60.0,
                    start_time=predicted_time.isoformat(),
                    start_index=start_index
                )
            else:
                logger.warning(
                    "👤 No scheduled departure at user's origin, using current time",
                    user_origin=user_origin,
                )
                predicted_time = now_et() + base_delay
                start_index = user_origin_index
                
        elif reference_stop is not None:
            # Train has made progress but no user context - use dynamic predictions
            reference_index = stops.index(reference_stop)
            
            # Calculate accumulated delay to propagate forward
            base_delay = self._calculate_base_delay(reference_stop, reference_time)
            
            # Start predictions from the reference stop to predict next station arrivals
            start_index = reference_index
            
            # Always use the reference time - don't adjust it
            # The train may have been traveling since that time
            predicted_time = reference_time
            
            logger.info(
                "🚂 Dynamic prediction mode (no user origin)",
                train_id=journey.train_id,
                reference_station=_get_station_code(reference_stop),
                reference_index=reference_index,
                start_index=start_index,
                base_delay_minutes=base_delay.total_seconds() / 60.0,
                departure_source=getattr(reference_stop, "departure_source", "unknown")
            )
                
        else:
            # No departures and no user context - start from first stop
            origin_stop = stops[0]
            if (
                hasattr(origin_stop, "scheduled_departure")
                and origin_stop.scheduled_departure
            ):
                predicted_time = ensure_timezone_aware(origin_stop.scheduled_departure)
                logger.info(
                    "🚂 Origin-based prediction mode",
                    station=_get_station_code(origin_stop),
                    scheduled_departure=predicted_time.isoformat(),
                )
            else:
                predicted_time = now_et()
                logger.warning(
                    "🚂 No scheduled departure, using current time",
                    station=_get_station_code(origin_stop),
                )
            start_index = 0
            base_delay = timedelta(0)

        # Check if we're past the destination
        if start_index >= len(stops) - 1:
            logger.info(
                "🏁 Train at or past destination, no predictions needed",
                train_id=journey.train_id,
                start_index=start_index,
                total_stops=len(stops),
            )
            return

        logger.info(
            "🎯 Prediction setup complete",
            train_id=journey.train_id,
            total_stops=len(stops),
            start_index=start_index,
            stops_to_predict=len(stops) - start_index - 1,
            base_delay_minutes=base_delay.total_seconds() / 60.0 if 'base_delay' in locals() else 0,
        )

        # Process each remaining segment
        # Always use start_index (determined by prediction strategy above)
        for i in range(start_index, len(stops) - 1):
            from_stop = stops[i]
            to_stop = stops[i + 1]

            # Never predict arrival at user's origin station (they board there)
            if user_origin_index is not None and (i + 1) == user_origin_index:
                logger.info(
                    "🚫 Skipping prediction for user's origin station",
                    station=_get_station_code(to_stop),
                    reason="user_origin_station"
                )
                continue

            # Skip prediction if the destination stop has already departed
            if to_stop.has_departed_station:
                logger.info(
                    "⏭️ Skipping prediction for already departed stop",
                    station=_get_station_code(to_stop),
                    has_departed=True,
                    departure_source=getattr(to_stop, "departure_source", "unknown")
                )
                continue

            # Get recent times for this segment
            segment_times = await self._get_recent_segment_times(
                db,
                _get_station_code(from_stop),
                _get_station_code(to_stop),
                journey.data_source or "NJT",
            )

            # Calculate transit time for this segment
            transit_minutes = self._calculate_segment_time(
                segment_times, from_stop, to_stop
            )

            # Check for unreasonable segment time
            if transit_minutes > self.MAX_SEGMENT_MINUTES:
                logger.warning(
                    "segment_time_too_long",
                    from_station=_get_station_code(from_stop),
                    to_station=_get_station_code(to_stop),
                    minutes=transit_minutes,
                )
                # Fall back to using updated arrival if available
                if hasattr(to_stop, "updated_arrival") and to_stop.updated_arrival:
                    to_stop.predicted_arrival = ensure_timezone_aware(
                        to_stop.updated_arrival
                    )
                    to_stop.predicted_arrival_samples = 0  # No samples, using fallback
                    predicted_time = to_stop.predicted_arrival
                    logger.info(
                        "🔄 Used updated_arrival fallback",
                        station=_get_station_code(to_stop),
                        updated_arrival=predicted_time.isoformat()
                    )
                else:
                    # Skip prediction for this stop
                    to_stop.predicted_arrival = None
                    to_stop.predicted_arrival_samples = 0
                    logger.info(
                        "❌ Skipped prediction due to unreasonable segment time",
                        station=_get_station_code(to_stop)
                    )
                continue

            # Add transit time to get arrival at next stop
            predicted_time = predicted_time + timedelta(minutes=transit_minutes)

            # If the prediction is in the past, we need to handle this carefully
            current_time = now_et()
            if predicted_time < current_time:
                # Check how far in the past the prediction is
                delay_minutes = (current_time - predicted_time).total_seconds() / 60.0
                
                if delay_minutes > 10:
                    # Prediction is very stale - train likely already arrived
                    # Skip this prediction entirely
                    logger.info(
                        "🚫 Skipping very stale prediction",
                        station=_get_station_code(to_stop),
                        calculated_time=predicted_time.isoformat(),
                        current_time=current_time.isoformat(),
                        delay_minutes=round(delay_minutes, 1),
                        reason="prediction_too_old"
                    )
                    to_stop.predicted_arrival = None
                    to_stop.predicted_arrival_samples = 0
                    continue
                else:
                    # Prediction is slightly in past - train should arrive soon
                    # Use predicted_time's timezone to avoid timezone mismatches
                    minutes_to_add = min(2, max(1, delay_minutes + 0.5))  # Add 1-2 minutes
                    adjusted_time = predicted_time + timedelta(minutes=minutes_to_add)
                    logger.info(
                        "⏰ Adjusted past prediction to near future", 
                        station=_get_station_code(to_stop),
                        calculated_time=predicted_time.isoformat(),
                        adjusted_to=adjusted_time.isoformat(),
                        delay_minutes=round(delay_minutes, 1),
                        reason="prediction_slightly_past",
                        adjustment_minutes=round(minutes_to_add, 1)
                    )
                    predicted_time = adjusted_time

            # Store prediction and sample count
            to_stop.predicted_arrival = predicted_time
            to_stop.predicted_arrival_samples = len(segment_times)

            logger.info(
                "✅ Prediction stored",
                station=_get_station_code(to_stop),
                predicted_arrival=predicted_time.isoformat(),
                samples=len(segment_times),
                transit_minutes=round(transit_minutes, 1),
                from_station=_get_station_code(from_stop),
                prediction_mode="dynamic" if reference_stop else "static"
            )

    def _find_current_position(self, stops: list[Any]) -> int:
        """
        Find the index of the last departed stop.

        Returns:
            Index of the current position (last departed stop)
        """
        current_index = 0

        for i, stop in enumerate(stops):
            if stop.has_departed_station:
                current_index = i
            elif hasattr(stop, "actual_departure") and stop.actual_departure:
                # Check if actual departure is in the past
                if ensure_timezone_aware(stop.actual_departure) <= now_et():
                    current_index = i

        return current_index

    def _find_reference_point(self, stops: list[Any]) -> tuple[Any | None, Any | None]:
        """
        Find the best reference point for predictions.
        
        Priority:
        1. Latest stop with actual_departure (most accurate)
        2. Latest stop with has_departed_station=true (use scheduled + buffer)
        3. None (use origin-based predictions)
        
        Args:
            stops: List of stop objects in sequence order
            
        Returns:
            Tuple of (reference_stop, reference_time) or (None, None)
        """
        latest_with_actual = None
        latest_departed = None
        
        for stop in stops:
            if stop.has_departed_station:
                latest_departed = stop
                if hasattr(stop, "actual_departure") and stop.actual_departure:
                    latest_with_actual = stop
        
        if latest_with_actual:
            # Best case: we have an actual departure time
            logger.info(
                "📍 Using actual departure as reference",
                station=_get_station_code(latest_with_actual),
                actual_departure=latest_with_actual.actual_departure.isoformat(),
                departure_source=getattr(latest_with_actual, "departure_source", "unknown")
            )
            return latest_with_actual, ensure_timezone_aware(latest_with_actual.actual_departure)
        elif latest_departed:
            # Second best: inferred departure, use scheduled time + buffer
            buffer = self._calculate_departure_buffer(latest_departed)
            reference_time = ensure_timezone_aware(latest_departed.scheduled_departure) + buffer
            
            logger.info(
                "📍 Using inferred departure as reference",
                station=_get_station_code(latest_departed),
                scheduled_departure=latest_departed.scheduled_departure.isoformat(),
                departure_source=getattr(latest_departed, "departure_source", "unknown"),
                buffer_minutes=buffer.total_seconds() / 60.0,
                reference_time=reference_time.isoformat()
            )
            return latest_departed, reference_time
        else:
            # No departures yet, will use origin-based predictions
            logger.info("📍 No departed stops found, will use origin-based predictions")
            return None, None

    def _calculate_departure_buffer(self, stop: Any) -> timedelta:
        """
        Calculate time buffer for inferred departures based on departure source.
        
        Args:
            stop: Stop object with departure_source attribute
            
        Returns:
            Time buffer to add to scheduled departure
        """
        departure_source = getattr(stop, "departure_source", None)
        
        if departure_source == "time_inference":
            # Already 5+ minutes late by definition of time_inference
            return timedelta(minutes=5)
        elif departure_source == "sequential_inference":
            # Conservative estimate - train is likely running on schedule or slightly late
            return timedelta(minutes=2)
        elif departure_source == "api_explicit":
            # API confirmed departure, likely close to scheduled time
            return timedelta(minutes=1)
        else:
            # Unknown source, use minimal buffer
            return timedelta(minutes=0)

    def _calculate_base_delay(self, stop: Any, reference_time: Any) -> timedelta:
        """
        Calculate accumulated delay based on the reference stop.
        
        Args:
            stop: Reference stop object
            reference_time: Actual or estimated departure time from reference stop
            
        Returns:
            Base delay to propagate to future predictions
        """
        if not hasattr(stop, "scheduled_departure") or not stop.scheduled_departure:
            logger.info(
                "⚠️ No scheduled departure for reference stop, assuming no delay",
                station=_get_station_code(stop)
            )
            return timedelta(0)
        
        scheduled_time = ensure_timezone_aware(stop.scheduled_departure)
        reference_time = ensure_timezone_aware(reference_time)
        
        delay = reference_time - scheduled_time
        
        logger.info(
            "📊 Calculated base delay",
            station=_get_station_code(stop),
            scheduled=scheduled_time.isoformat(),
            reference=reference_time.isoformat(),
            delay_minutes=delay.total_seconds() / 60.0,
            departure_source=getattr(stop, "departure_source", "unknown")
        )
        
        return delay

    async def _get_recent_segment_times(
        self, db: AsyncSession, from_station: str, to_station: str, data_source: str
    ) -> list[float]:
        """
        Get actual transit times from recent trains on this segment.

        Args:
            db: Database session
            from_station: Origin station code
            to_station: Destination station code
            data_source: NJT or AMTRAK

        Returns:
            List of transit times in minutes
        """
        cutoff_time = now_et() - timedelta(hours=self.LOOKBACK_HOURS)

        logger.info(
            "🕐 Querying segment times",
            from_station=from_station,
            to_station=to_station,
            data_source=data_source,
            lookback_hours=self.LOOKBACK_HOURS,
            cutoff_time=cutoff_time.isoformat(),
        )

        # First check if there are ANY segment times for this route (ever)
        total_count_stmt = select(SegmentTransitTime).where(
            and_(
                SegmentTransitTime.from_station_code == from_station,
                SegmentTransitTime.to_station_code == to_station,
                SegmentTransitTime.data_source == data_source,
            )
        )
        total_result = await db.execute(total_count_stmt)
        total_segments = total_result.fetchall()

        logger.info(
            "📊 Segment analysis",
            from_station=from_station,
            to_station=to_station,
            total_segments_all_time=len(total_segments),
        )

        if len(total_segments) > 0:
            # Show some example times for debugging
            try:
                latest_segments = sorted(
                    total_segments, key=lambda x: x[0].departure_time, reverse=True
                )[:3]
                logger.info(
                    "🔍 Latest segment examples",
                    examples=[
                        (s[0].departure_time.isoformat(), s[0].actual_minutes)
                        for s in latest_segments
                    ],
                )
            except (AttributeError, IndexError):
                # Handle case where segments don't have expected structure (e.g., in tests)
                logger.debug(
                    "📊 Segment structure not as expected, skipping examples",
                    total_segments_structure=(
                        type(total_segments[0]) if total_segments else None
                    ),
                )

        stmt = (
            select(SegmentTransitTime.actual_minutes)
            .where(
                and_(
                    SegmentTransitTime.from_station_code == from_station,
                    SegmentTransitTime.to_station_code == to_station,
                    SegmentTransitTime.data_source == data_source,
                    SegmentTransitTime.departure_time >= cutoff_time,
                    # Sanity filters
                    SegmentTransitTime.actual_minutes > 0,
                    SegmentTransitTime.actual_minutes <= self.MAX_SEGMENT_MINUTES,
                )
            )
            .order_by(SegmentTransitTime.departure_time.desc())
            .limit(20)  # Cap at 20 most recent
        )

        result = await db.execute(stmt)
        times = [row[0] for row in result.fetchall()]

        logger.info(
            "⏱️ Recent segment query results",
            from_station=from_station,
            to_station=to_station,
            recent_count=len(times),
            times=times[:5] if times else [],  # Log first 5 for debugging
            min_samples_required=self.MIN_SAMPLES,
            will_predict=len(times) >= self.MIN_SAMPLES,
        )

        # If no actual segment times exist, try to get scheduled times from recent journeys
        if len(times) == 0:
            logger.info(
                "🕰️ No actual segment data, trying scheduled times from recent journeys"
            )
            times = await self._get_recent_scheduled_segment_times(
                db, from_station, to_station, data_source
            )

        return times

    async def _get_recent_scheduled_segment_times(
        self, db: AsyncSession, from_station: str, to_station: str, data_source: str
    ) -> list[float]:
        """
        Get scheduled transit times from recent journeys as a fallback.

        Args:
            db: Database session
            from_station: Origin station code
            to_station: Destination station code
            data_source: NJT or AMTRAK

        Returns:
            List of scheduled transit times in minutes
        """
        cutoff_time = now_et() - timedelta(hours=self.LOOKBACK_HOURS)

        logger.info(
            "📋 Querying scheduled segment times",
            from_station=from_station,
            to_station=to_station,
            data_source=data_source,
            cutoff_time=cutoff_time.isoformat(),
        )

        # Query for recent journeys that have both stops in sequence
        from sqlalchemy import text

        # Use raw SQL for this complex query
        stmt = text(
            """
            SELECT
                EXTRACT(EPOCH FROM (js2.scheduled_arrival - js1.scheduled_departure)) / 60.0 as minutes
            FROM train_journeys tj
            JOIN journey_stops js1 ON tj.id = js1.journey_id AND js1.station_code = :from_station
            JOIN journey_stops js2 ON tj.id = js2.journey_id AND js2.station_code = :to_station
            WHERE tj.data_source = :data_source
            AND tj.last_updated_at >= :cutoff_time
            AND js1.stop_sequence < js2.stop_sequence
            AND js1.scheduled_departure IS NOT NULL
            AND js2.scheduled_arrival IS NOT NULL
            LIMIT 10
        """
        )

        result = await db.execute(
            stmt,
            {
                "from_station": from_station,
                "to_station": to_station,
                "data_source": data_source,
                "cutoff_time": cutoff_time,
            },
        )
        scheduled_rows = result.fetchall()

        # Extract valid transit times
        times = []
        for row in scheduled_rows:
            minutes = float(row.minutes) if row.minutes else 0
            if 0 < minutes <= self.MAX_SEGMENT_MINUTES:
                times.append(minutes)

        logger.info(
            "📋 Scheduled times fallback results",
            from_station=from_station,
            to_station=to_station,
            scheduled_count=len(times),
            times=times[:3] if times else [],
        )  # Log first 3

        return times

    def _calculate_segment_time(
        self, segment_times: list[float], from_stop: Any, to_stop: Any
    ) -> float:
        """
        Calculate the expected transit time for a segment.

        Uses median of recent times if available, otherwise falls back to scheduled.

        Args:
            segment_times: Recent actual transit times
            from_stop: Origin stop object
            to_stop: Destination stop object

        Returns:
            Expected transit time in minutes
        """
        if len(segment_times) >= self.MIN_SAMPLES:
            # Use median for robustness against outliers
            median_time = statistics.median(segment_times)
            logger.info(
                "🎯 Using median prediction",
                from_station=_get_station_code(from_stop),
                to_station=_get_station_code(to_stop),
                samples=len(segment_times),
                median_minutes=round(median_time, 1),
                all_times=segment_times,
            )
            return median_time

        logger.info(
            "📉 Insufficient samples, using fallback",
            from_station=_get_station_code(from_stop),
            to_station=_get_station_code(to_stop),
            sample_count=len(segment_times),
            min_required=self.MIN_SAMPLES,
        )

        # Fallback to scheduled times if available
        if (
            hasattr(from_stop, "scheduled_departure")
            and hasattr(to_stop, "scheduled_arrival")
            and from_stop.scheduled_departure
            and to_stop.scheduled_arrival
        ):

            scheduled_delta = ensure_timezone_aware(
                to_stop.scheduled_arrival
            ) - ensure_timezone_aware(from_stop.scheduled_departure)
            scheduled_minutes = scheduled_delta.total_seconds() / 60.0

            # Sanity check scheduled time
            if 0 < scheduled_minutes <= self.MAX_SEGMENT_MINUTES:
                logger.info(
                    "📅 Using scheduled time fallback",
                    from_station=_get_station_code(from_stop),
                    to_station=_get_station_code(to_stop),
                    scheduled_minutes=round(scheduled_minutes, 1),
                )
                return scheduled_minutes

        # Last resort: use a conservative default
        # This should rarely happen in practice
        logger.warning(
            "❌ No segment data available, using default",
            from_station=_get_station_code(from_stop),
            to_station=_get_station_code(to_stop),
            default_minutes=15.0,
        )
        return 15.0  # Conservative 15-minute default
