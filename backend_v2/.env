# TrackRat V2 Backend Configuration
# Copy this file to .env and update with your values

# Environment
TRACKRAT_ENVIRONMENT=development
TRACKRAT_DEBUG=true
TRACKRAT_LOG_LEVEL=INFO

# API Settings
TRACKRAT_API_HOST=0.0.0.0
TRACKRAT_API_PORT=8000

# Database
# PostgreSQL connection URL
TRACKRAT_DATABASE_URL=postgresql+asyncpg://trackratuser:password@localhost:5433/trackratdb

# NJ Transit API
TRACKRAT_NJT_API_URL=https://raildata.njtransit.com/api
TRACKRAT_NJT_API_TOKEN=638824610065690152

# Collection Settings
TRACKRAT_DISCOVERY_INTERVAL_MINUTES=5
TRACKRAT_JOURNEY_UPDATE_INTERVAL_MINUTES=15
TRACKRAT_DATA_STALENESS_SECONDS=60

# Monitoring
TRACKRAT_ENABLE_METRICS=true

# Sentry Configuration
SENTRY_DSN=https://932919d4e814a93ace4a6bdac65a4da9@o4510043461058560.ingest.us.sentry.io/4510043532754944
SENTRY_TRACES_SAMPLE_RATE=1.0
