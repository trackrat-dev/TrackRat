# Default deployment configuration
# These settings can be overridden by environment-specific configs or command line flags

# Build settings
DEFAULT_BUILD_TARGET="runtime"
DEFAULT_DOCKERFILE="Dockerfile"
BUILD_CACHE_FROM="type=registry"
BUILD_CACHE_TO="type=registry,mode=max"

# Deployment behavior
DEFAULT_SKIP_TESTS=false
DEFAULT_AUTO_APPROVE=false
DEFAULT_DRY_RUN=false

# Health check configuration
HEALTH_CHECK_MAX_ATTEMPTS=5
HEALTH_CHECK_RETRY_DELAY=30
HEALTH_CHECK_INITIAL_DELAY=30

# Terraform settings
TERRAFORM_PARALLELISM=10
TERRAFORM_LOCK_TIMEOUT="5m"

# Service configuration
MAX_INSTANCES_API=100
MAX_INSTANCES_SCHEDULER=10
MIN_INSTANCES_API=0
MIN_INSTANCES_SCHEDULER=0

# Rollback settings
KEEP_PREVIOUS_VERSIONS=3
ROLLBACK_ON_FAILURE=true

# Logging
LOG_LEVEL="INFO"
SHOW_DOCKER_OUTPUT=false
SHOW_TERRAFORM_OUTPUT=false